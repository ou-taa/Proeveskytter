@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Glemt adgangskode?";
}

<h1>@ViewData["Title"]</h1>
<p>Hvis du har glemt din adgangskode, eller gerne vil ændre den, kan du indtaste din email-adresse herunder.</p>
<p>Du vil så modtage en e-mail med et link, hvor du kan ændre adgangskoden</p>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="navn@example.com" />
                <label asp-for="Input.Email" class="form-label"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary">Nulstil adgangskode</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
