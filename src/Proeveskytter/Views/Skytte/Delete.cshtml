@model Proeveskytter.Models.Entities.Skytte

@{
    ViewData["Title"] = "Slet Skytte";
}

<h1>Slet Skytte</h1>

<h3>Er du sikker på du vil slette denne skytte?</h3>
<div>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Navn)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Navn)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IdType)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IdType)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IdNr)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IdNr)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Slet" class="btn btn-danger" />
    </form>
</div>
<hr />
<div>
    <a asp-action="Index">Skytteliste</a>
</div>
