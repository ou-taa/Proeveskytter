@using Proeveskytter.Models.Entities
@model IEnumerable<Proeveskytter.Models.Entities.Skytte>

@{
    ViewData["Title"] = "Ousted Tåning skytteforening - Logbog";
}
<p class="d-print-none">
    Hvis du skal sende denne logbog til politiet, skal du udskrive denne side til et pdf-dokument, og sende pdf-dokumentet til politiet.
</p>
<table class="table table-bordered border-dark .table-sm">
    <thead>
        <tr>
            <th colspan="4">
                Ousted Tåning skytteforening - Logbog - Prøveskytter
            </th>
        </tr>
        <tr>
            <th colspan="3">
                Prøveskytten
            </th>
            <th>Prøveskydning</th>
        </tr>
        <tr>
            <th>
                Navn
            </th>
            <th>
                ID-Type
            </th>
            <th>
                ID-nummer
            </th>
            <th>
                Dato
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (Skytte skytte in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => skytte.Navn)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => skytte.IdType)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => skytte.IdNr)
                </td>
                <td>
                    <ul>
                        @foreach (Skydning skydning in skytte.Skydninger)
                        {
                            <li>
                                @Html.DisplayFor(modelItem => skydning.Dato)

                            </li>
                        }
                    </ul>
                </td>
            </tr>
        }
    </tbody>
</table>
