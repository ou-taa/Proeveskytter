@model Proeveskytter.Models.Skydning

@{
    ViewData["Title"] = "Opret ny prøveskydning";
}

<h2>Opret ny prøveskydning</h2>
<div>
    <dl class="row">
        <dt class="col-sm-2">
            Skytte
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Skytte.Navn)
        </dd>
    </dl>
</div>
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            @Html.HiddenFor(model => model.SkytteId)    
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Dato" class="control-label"></label>
                <input asp-for="Dato" class="form-control" />
                <span asp-validation-for="Dato" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Opret" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Tilbage til listen af skydninger</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
